[flake8]
max-line-length = 88
extend-ignore = E203, W503  # conflitos com Black
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    .mypy_cache,
    .tox,
    *.pyi
per-file-ignores =
    __init__.py:F401
select = C,E,F,W,B,B950
# B950: linha mais longa que 88 mas com erro? Na verdade, o flake8-bugbear já trata.
# Vamos usar o plugin flake8-bugbear para regras adicionais
# Instale: pip install flake8-bugbear