# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,...

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=value
JWT_REFRESH_TOKEN_LIFETIME_DAYS=value

# ─── Image token (HMAC) ───────────────────────────────────────────────────────
# Chave dedicada para assinar tokens de acesso a imagens (recomendado).
# Se omitida, usa SECRET_KEY como fallback.
IMAGE_TOKEN_SECRET=your-image-token-secret-here
# Tempo de vida do token em segundos (padrão: 900 = 15 min)
IMAGE_TOKEN_TTL_SECONDS=900
